// Prisma schema cho PostgreSQL (chế độ offline)
// Chạy: npx prisma migrate dev --name init
// Xem DB: npx prisma studio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Mức độ quyền cho từng module nghiệp vụ
enum PermissionLevel {
  hidden      // Ẩn hoàn toàn — không thấy tab, không thao tác được
  viewOnly    // Chỉ xem — có thể xem dữ liệu nhưng không thêm/sửa/xóa
  fullAccess  // Toàn quyền — xem, thêm, sửa, xóa
}

model NguoiDung {
  id                String    @id @default(cuid())
  ten               String
  email             String?   @unique
  matKhau           String
  soDienThoai       String?   @unique
  vaiTro            String    @default("nhanVien") // admin | chuNha | dongChuTro | quanLy | nhanVien
  chucVu            String? // Chức vụ nghiệp vụ con cho quanLy | nhanVien
  anhDaiDien        String?
  trangThai         String    @default("hoatDong") // hoatDong | khoa
  zaloChatId        String? // Zalo bot chat_id đã xác thực (tài khoản bot mặc định)
  zaloChatIds       Json? // Map { [botAccountId]: chatId } — lưu chatId theo từng tài khoản bot
  pendingZaloChatId String? // Zalo bot chat_id chờ xác nhận (từ getUpdates)
  nhanThongBaoZalo  Boolean   @default(false) // Có gửi thông báo Zalo không
  zaloAccountId     String? // Account ID (own_id) trên bot server dùng gửi tin
  zaloBotServerUrl  String? // URL bot server riêng (ghi đè CaiDat nếu có)
  zaloBotUsername   String? // Username bot server riêng
  zaloBotPassword   String? // Password bot server riêng
  zaloBotTtl        Int? // TTL tin nhắn (ms), 0 = không tự hủy
  zaloWebhookToken  String?   @unique // Token ngẫu nhiên cho webhook URL riêng
  zaloViTri         Json? // Vị trí slot Zalo: { "buildingId": number } — VD quản lý 2 = { "bldg123": 2 }
  hoatDongCuoi      DateTime? // Lần hoạt động cuối trên web (dùng xác định online/offline)
  ngayTao           DateTime  @default(now())
  ngayCapNhat       DateTime  @updatedAt

  // Relations
  toaNha                ToaNha[]
  toaNhaQuanLy          ToaNhaNguoiQuanLy[]
  caiDatChuNha          CaiDatChuNha?
  chiSo                 ChiSoDienNuoc[]
  thanhToan             ThanhToan[]
  suCoXuLy              SuCo[]                 @relation("NguoiXuLy")
  thongBaoGui           ThongBao[]
  yeuCauPheDuyet        YeuCauThayDoi[]
  zaloThongBaoCaiDat    ZaloThongBaoCaiDat[]
  zaloDongChuTroThreads ZaloDongChuTroThread[]
  danhBaNgoai           DanhBaNgoai[]
  khachThueTao          KhachThue[]            @relation("KhachThueNguoiTao")
  hoaDonTao             HoaDon[]               @relation("HoaDonNguoiTao")
  lichTrucCa            LichTrucCa[]           @relation("NguoiDungLichTruc")
  lichTrucCaTao         LichTrucCa[]           @relation("NguoiTaoLichTruc")
  caiDatEmail           CaiDatEmail?
  emailLog              EmailLog[]
  congViecTao           CongViec[]             @relation("CongViecNguoiTao")
  congViecXuLy          CongViec[]             @relation("CongViecNguoiXuLy")
  congViecLichSu        CongViecLichSu[]
  phieuNhapKho          PhieuNhapKho[]
  phieuXuatKho          PhieuXuatKho[]
  baoDuongPhuTrach      BaoDuong[]             @relation("BaoDuongNguoiPhuTrach")
  baoDuongLichSu        BaoDuongLichSu[]
}

model ToaNha {
  id             String    @id @default(cuid())
  tenToaNha      String
  diaChi         Json // { soNha, duong, phuong, quan, thanhPho }
  moTa           String?
  anhToaNha      String[]
  chuSoHuuId     String
  chuSoHuu       NguoiDung @relation(fields: [chuSoHuuId], references: [id])
  tongSoPhong    Int       @default(0)
  tienNghiChung  String[]
  lienHePhuTrach Json      @default("[]") // [{ ten, soDienThoai, vaiTro? }]
  zaloNhomChat   Json      @default("[]") // [{ tang?: number|null, threadId: string, label?: string }] — null tang = toàn tòa
  ngayTao        DateTime  @default(now())
  ngayCapNhat    DateTime  @updatedAt

  phong                 Phong[]
  nguoiQuanLy           ToaNhaNguoiQuanLy[]
  zaloThongBaoCaiDat    ZaloThongBaoCaiDat[]
  zaloDongChuTroThreads ZaloDongChuTroThread[]
  caiDatToaNha          CaiDatToaNha?
  lichTrucCa            LichTrucCa[]
  congViec              CongViec[]
  tonKho                TonKho[]
  phieuNhapKho          PhieuNhapKho[]
  phieuXuatKho          PhieuXuatKho[]
  baoDuong              BaoDuong[]
}

// Bảng gán người quản lý cho tòa nhà (role: quanLy)
// Mỗi module nghiệp vụ có 3 mức: hidden (ẩn), viewOnly (chỉ xem), fullAccess (toàn quyền)
model ToaNhaNguoiQuanLy {
  toaNhaId    String
  nguoiDungId String
  toaNha      ToaNha    @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)
  ngayTao     DateTime  @default(now())

  // Quyền hạn 3 mức cho từng module nghiệp vụ
  mucDoHopDong          PermissionLevel @default(fullAccess) // Hợp đồng
  mucDoHoaDon           PermissionLevel @default(fullAccess) // Hóa đơn
  mucDoThanhToan        PermissionLevel @default(fullAccess) // Thanh toán
  mucDoSuCo             PermissionLevel @default(fullAccess) // Sự cố
  mucDoKichHoatTaiKhoan PermissionLevel @default(fullAccess) // Kích hoạt/thu hồi đăng nhập khách thuê
  mucDoZalo             PermissionLevel @default(fullAccess) // Zalo
  mucDoZaloMonitor      PermissionLevel @default(fullAccess) // Zalo Monitor
  mucDoCongViec         PermissionLevel @default(fullAccess) // Công việc / Kanban
  mucDoKho             PermissionLevel @default(fullAccess) // Kho (vật tư, tồn kho, nhập-xuất)
  mucDoBaoDuong        PermissionLevel @default(fullAccess) // Bảo dưỡng
  mucDoCaiDatHotline   PermissionLevel @default(fullAccess) // Cài đặt Hotline
  mucDoCaiDatEmail     PermissionLevel @default(fullAccess) // Cài đặt Email

  @@id([toaNhaId, nguoiDungId])
}

// Cài đặt thông báo Zalo theo từng người × từng tòa nhà
// Chủ trọ: có thêm cột chuyển quyền cho quản lý theo từng mục
model ZaloThongBaoCaiDat {
  id          String @id @default(cuid())
  nguoiDungId String
  toaNhaId    String

  // Bật/tắt nhận từng loại thông báo
  nhanSuCo     Boolean @default(true)
  nhanHoaDon   Boolean @default(true)
  nhanTinKhach Boolean @default(true)
  nhanNguoiLa  Boolean @default(true)
  nhanNhacNho  Boolean @default(true)

  // Chuyển quyền cho quản lý (chỉ có ý nghĩa với chủ trọ)
  // Khi bật: chỉ trạng thái cuối (daXong, daThanhToan) mới báo lại chủ trọ
  chuyenSuCoChoQL     Boolean @default(false)
  chuyenHoaDonChoQL   Boolean @default(false)
  chuyenTinKhachChoQL Boolean @default(false)
  chuyenNguoiLaChoQL  Boolean @default(false)
  chuyenNhacNhoChoQL  Boolean @default(false)

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt

  nguoiDung NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)
  toaNha    ToaNha    @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)

  @@unique([nguoiDungId, toaNhaId])
}

model Phong {
  id           String   @id @default(cuid())
  maPhong      String
  toaNhaId     String
  toaNha       ToaNha   @relation(fields: [toaNhaId], references: [id])
  tang         Int
  dienTich     Float
  giaThue      Float
  tienCoc      Float
  moTa         String?
  anhPhong     String[]
  tienNghi     String[]
  trangThai    String   @default("trong") // trong | daDat | dangThue | baoTri
  soNguoiToiDa Int
  ngayTinhTien Int      @default(1) // Ngày thu tiền hàng tháng (1-28)
  ngayTao      DateTime @default(now())
  ngayCapNhat  DateTime @updatedAt

  hopDong  HopDong[]
  chiSo    ChiSoDienNuoc[]
  hoaDon   HoaDon[]
  suCo     SuCo[]
  thongBao ThongBaoPhong[]
  congViec CongViec[]
  phieuXuatKho PhieuXuatKho[]
  baoDuong BaoDuong[]

  @@unique([maPhong, toaNhaId])
}

model KhachThue {
  id                String     @id @default(cuid())
  hoTen             String
  soDienThoai       String?    @unique // Tùy chọn — cần ít nhất 1 trong soDienThoai hoặc email
  email             String?    @unique // Tùy chọn — cần ít nhất 1 trong soDienThoai hoặc email
  cccd              String     @unique
  ngaySinh          DateTime
  gioiTinh          String // nam | nu | khac
  queQuan           String
  anhCCCD           Json? // { matTruoc, matSau }
  ngheNghiep        String?
  matKhau           String?
  zaloChatId        String? // Zalo bot chat_id đã xác thực (tài khoản bot mặc định)
  zaloChatIds       Json? // Map { [botAccountId]: chatId } — lưu chatId theo từng tài khoản bot
  pendingZaloChatId String? // Zalo bot chat_id chờ xác nhận (phát hiện từ getUpdates)
  nhanThongBaoZalo  Boolean    @default(false) // Có gửi thông báo Zalo không
  batDangNhapWeb    Boolean    @default(false) // Bật/tắt đăng nhập web per khách thuê (mặc định tắt)
  trangThai         String     @default("chuaThue") // dangThue | daTraPhong | chuaThue
  nguoiTaoId        String? // ID của NguoiDung tạo khách thuê này
  nguoiTao          NguoiDung? @relation("KhachThueNguoiTao", fields: [nguoiTaoId], references: [id], onDelete: SetNull)
  ngayTao           DateTime   @default(now())
  ngayCapNhat       DateTime   @updatedAt

  hopDong        HopDong[]
  daiDienHopDong HopDong[]       @relation("NguoiDaiDien")
  hoaDon         HoaDon[]
  suCo           SuCo[]
  yeuCauThayDoi  YeuCauThayDoi[]
}

model HopDong {
  id                 String    @id @default(cuid())
  maHopDong          String
  phongId            String
  phong              Phong     @relation(fields: [phongId], references: [id])
  toaNhaId           String?
  nguoiDaiDienId     String
  nguoiDaiDien       KhachThue @relation("NguoiDaiDien", fields: [nguoiDaiDienId], references: [id])
  ngayBatDau         DateTime
  ngayKetThuc        DateTime
  giaThue            Float
  tienCoc            Float
  chuKyThanhToan     String    @default("thang") // thang | quy | nam
  ngayThanhToan      Int
  dieuKhoan          String
  giaDien            Float
  giaNuoc            Float
  bangGiaDienLuyTien Json? // [{ tu, den, gia }] — null = giá phẳng theo giaDien
  bangGiaNuocLuyTien Json? // [{ tu, den, gia }] — null = giá phẳng theo giaNuoc
  chiSoDienBanDau    Float     @default(0)
  chiSoNuocBanDau    Float     @default(0)
  phiDichVu          Json      @default("[]") // [{ ten, gia }]
  trangThai          String    @default("hoatDong") // hoatDong | hetHan | daHuy
  fileHopDong        String?
  ngayTao            DateTime  @default(now())
  ngayCapNhat        DateTime  @updatedAt

  khachThue KhachThue[]
  hoaDon    HoaDon[]

  @@unique([maHopDong, toaNhaId])
}

model ChiSoDienNuoc {
  id            String    @id @default(cuid())
  phongId       String
  phong         Phong     @relation(fields: [phongId], references: [id])
  thang         Int
  nam           Int
  chiSoDienCu   Float
  chiSoDienMoi  Float
  soDienTieuThu Float     @default(0)
  chiSoNuocCu   Float
  chiSoNuocMoi  Float
  soNuocTieuThu Float     @default(0)
  anhChiSoDien  String?
  anhChiSoNuoc  String?
  nguoiGhiId    String
  nguoiGhi      NguoiDung @relation(fields: [nguoiGhiId], references: [id])
  ngayGhi       DateTime  @default(now())
  ngayTao       DateTime  @default(now())

  @@unique([phongId, thang, nam])
}

model HoaDon {
  id              String     @id @default(cuid())
  maHoaDon        String
  hopDongId       String
  hopDong         HopDong    @relation(fields: [hopDongId], references: [id])
  phongId         String
  phong           Phong      @relation(fields: [phongId], references: [id])
  toaNhaId        String?
  khachThueId     String?
  khachThue       KhachThue? @relation(fields: [khachThueId], references: [id], onDelete: SetNull)
  thang           Int
  nam             Int
  tienPhong       Float
  tienDien        Float
  soDien          Float      @default(0)
  chiSoDienBanDau Float      @default(0)
  chiSoDienCuoiKy Float      @default(0)
  chiTietDien     Json? // [{ bac, tu, den, soLuong, donGia, thanhTien }] — null = giá phẳng
  tienNuoc        Float
  soNuoc          Float      @default(0)
  chiSoNuocBanDau Float      @default(0)
  chiSoNuocCuoiKy Float      @default(0)
  chiTietNuoc     Json? // [{ bac, tu, den, soLuong, donGia, thanhTien }] — null = giá phẳng
  phiDichVu       Json       @default("[]")
  tongTien        Float
  daThanhToan     Float      @default(0)
  conLai          Float
  trangThai       String     @default("chuaThanhToan") // chuaThanhToan | daThanhToanMotPhan | daThanhToan | quaHan
  hanThanhToan    DateTime
  ghiChu          String?
  anhChiSoDien    String?
  anhChiSoNuoc    String?
  nguoiTaoId      String?
  nguoiTao        NguoiDung? @relation("HoaDonNguoiTao", fields: [nguoiTaoId], references: [id], onDelete: SetNull)
  ngayTao         DateTime   @default(now())
  ngayCapNhat     DateTime   @updatedAt

  thanhToan ThanhToan[]

  @@unique([maHoaDon, toaNhaId])
  @@index([nguoiTaoId])
}

model ThanhToan {
  id                  String    @id @default(cuid())
  hoaDonId            String
  hoaDon              HoaDon    @relation(fields: [hoaDonId], references: [id])
  soTien              Float
  phuongThuc          String // tienMat | chuyenKhoan | viDienTu
  thongTinChuyenKhoan Json? // { nganHang, soGiaoDich }
  ngayThanhToan       DateTime  @default(now())
  nguoiNhanId         String
  nguoiNhan           NguoiDung @relation(fields: [nguoiNhanId], references: [id])
  ghiChu              String?
  anhBienLai          String?
  ngayTao             DateTime  @default(now())
}

model SuCo {
  id            String     @id @default(cuid())
  phongId       String
  phong         Phong      @relation(fields: [phongId], references: [id])
  khachThueId   String
  khachThue     KhachThue  @relation(fields: [khachThueId], references: [id])
  tieuDe        String
  moTa          String
  anhSuCo       String[]
  loaiSuCo      String // dienNuoc | noiThat | vesinh | anNinh | khac
  mucDoUuTien   String     @default("trungBinh")
  trangThai     String     @default("moi") // moi | dangXuLy | daXong | daHuy
  nguoiXuLyId   String?
  nguoiXuLy     NguoiDung? @relation("NguoiXuLy", fields: [nguoiXuLyId], references: [id])
  ghiChuXuLy    String?
  ngayBaoCao    DateTime   @default(now())
  ngayXuLy      DateTime?
  ngayHoanThanh DateTime?
  ngayTao       DateTime   @default(now())
  ngayCapNhat   DateTime   @updatedAt
}

model ThongBao {
  id            String          @id @default(cuid())
  tieuDe        String
  noiDung       String
  loai          String          @default("chung") // chung | hoaDon | suCo | hopDong | khac
  nguoiGuiId    String
  nguoiGui      NguoiDung       @relation(fields: [nguoiGuiId], references: [id])
  nguoiNhan     String[] // array of NguoiDung/KhachThue IDs
  daDoc         String[] // array of IDs đã đọc
  trangThaiXuLy String          @default("chuaXuLy") // chuaXuLy | daXuLy | tuChoi | tamHoan
  ngayGui       DateTime        @default(now())
  ngayTao       DateTime        @default(now())
  toaNhaId      String?
  nhomChatIds   String[]        @default([]) // threadId nhóm Zalo gửi kèm
  fileDinhKem   String[]        @default([]) // URL file/ảnh đính kèm
  phong         ThongBaoPhong[]
}

model ThongBaoPhong {
  thongBaoId String
  phongId    String
  thongBao   ThongBao @relation(fields: [thongBaoId], references: [id])
  phong      Phong    @relation(fields: [phongId], references: [id])

  @@id([thongBaoId, phongId])
}

// Lịch sử tin nhắn Zalo Bot (webhook inbound + bot outbound)
model ZaloMessage {
  id            String   @id @default(cuid())
  chatId        String // Zalo ID của người dùng (người gửi)
  ownId         String? // Zalo ID tài khoản nhận (bot account)
  displayName   String? // Tên hiển thị Zalo
  content       String // Nội dung tin nhắn (text)
  attachmentUrl String? // URL ảnh / file đính kèm đầu tiên
  role          String // 'user' | 'bot'
  eventName     String? // Loại event Zalo (e.g. "follow", "message")
  rawPayload    Json? // Payload gốc từ Zalo (để AI đọc sau)
  createdAt     DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([ownId, createdAt])
  @@index([createdAt])
}

// Cài đặt hệ thống — chỉ admin đọc/ghi qua UI
model CaiDat {
  id          String   @id @default(cuid())
  khoa        String   @unique // key, e.g. "storage_provider"
  giaTri      String? // value (JSON string for complex values)
  moTa        String? // mô tả
  nhom        String   @default("chung") // chung | luuTru | thongBao | heThong | baoMat
  laBiMat     Boolean  @default(false) // true → che giá trị khi trả về client
  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}

// Yêu cầu thay đổi của khách thuê — chờ quản lý/chủ trọ phê duyệt
model YeuCauThayDoi {
  id              String     @id @default(cuid())
  khachThueId     String
  khachThue       KhachThue  @relation(fields: [khachThueId], references: [id])
  loai            String // thongTin | anhCCCD | nguoiCungPhong | thongBao
  noiDung         Json // { truoc: {...}, sau: {...}, moTa: "..." }
  trangThai       String     @default("choPheduyet") // choPheduyet | daPheduyet | tuChoi
  nguoiPheDuyetId String?
  nguoiPheDuyet   NguoiDung? @relation(fields: [nguoiPheDuyetId], references: [id])
  ghiChuPheDuyet  String?
  ngayTao         DateTime   @default(now())
  ngayCapNhat     DateTime   @updatedAt
}

// Thread ID Zalo của đồng chủ trọ — mỗi threadId có 1 bảng cài đặt thông báo riêng
model ZaloDongChuTroThread {
  id           String    @id @default(cuid())
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)
  toaNhaId     String
  toaNha       ToaNha    @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)
  threadId     String // Zalo thread/group ID
  ten          String? // Nhãn hiển thị (tùy chọn)
  loai         String    @default("user") // "user" | "group"
  // Cài đặt thông báo cho thread này
  nhanSuCo     Boolean   @default(true)
  nhanHoaDon   Boolean   @default(true)
  nhanTinKhach Boolean   @default(true)
  nhanNguoiLa  Boolean   @default(true)
  nhanNhacNho  Boolean   @default(true)
  ngayTao      DateTime  @default(now())
  ngayCapNhat  DateTime  @updatedAt

  @@unique([nguoiDungId, toaNhaId, threadId])
}

// Cài đặt per tòa nhà: Home Assistant + lưu trữ — do admin quản lý
model CaiDatToaNha {
  id       String @id @default(cuid())
  toaNhaId String @unique
  toaNha   ToaNha @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)

  // Home Assistant
  haUrl            String? // URL domain/IP của Home Assistant (e.g. https://ha.myhouse.com)
  haToken          String? // Long-lived access token
  haWebhookUrl     String? // URL webhook để HA gửi thông báo về app (hoặc app gửi đến HA)
  haAllowedThreads String? // JSON array: [{threadId, type}] — lọc thread được chuyển tiếp đến HA

  // Lưu trữ ảnh
  storageProvider     String  @default("local") // local | minio | cloudinary | both
  minioEndpoint       String?
  minioAccessKey      String?
  minioSecretKey      String?
  minioBucket         String?
  cloudinaryCloudName String?
  cloudinaryApiKey    String?
  cloudinaryApiSecret String?
  cloudinaryPreset    String?
  uploadMaxSizeMb     Int     @default(10)

  // Giới hạn vai trò theo tòa nhà — JSON: {"dongChuTro":2,"quanLy":3,"nhanVien":5}
  // null = dùng giới hạn chung (global)
  roleLimits String?

  // Gói tính năng nghiệp vụ của tòa nhà — JSON: { mucDoHopDong: 'fullAccess'|'viewOnly'|'hidden', ... }
  // null = tất cả quyền được bật (mặc định cho tòa nhà mới)
  // Admin cấu hình gói này, tất cả người dùng trong tòa nhà đều kế thừa
  businessPermissions String?

  // Văn mẫu Zalo tùy chỉnh — JSON: { friendMsgKT?, friendMsgQL?, followUpMsgKT?, followUpMsgQL? }
  // Hỗ trợ biến: {ten}, {tenToaNha}, {diaChiNgan}, {diaChiDay}, {phong}, {soNha}, {duong}
  // null = dùng văn mẫu mặc định
  zaloVanMau String?

  // Quyền sử dụng tính năng Zalo per role per tòa nhà
  // JSON: { admin: { chuNha: {...}, dongChuTro: {...}, quanLy: {...}, nhanVien: {...} }, chuNha: { dongChuTro: {...}, quanLy: {...}, nhanVien: {...} } }
  // Mỗi object chứa: { botServer, trucTiep, proxy, webhook, tinTuDong, testGui, ketBan, theoDoiTin, zaloMonitor }
  // null = tất cả tính năng được bật (mặc định)
  // Quyền thực tế = admin[role] AND chuNha[role] (admin là trần, chuNha chỉ hạn chế thêm)
  zaloQuyenTinhNang String?

  // Đăng nhập web cho khách thuê — admin bật/tắt per tòa nhà
  // adminBatDangNhapKT = true: admin cho phép tính năng đăng nhập KT ở tòa nhà này
  // Khi admin bật → chủ trọ mới thấy và có quyền bật/tắt (chuTroBatDangNhapKT)
  // Khi admin tắt → tất cả khách thuê tòa nhà này không thể đăng nhập web
  adminBatDangNhapKT  Boolean @default(false) // Admin cho phép tính năng đăng nhập KT
  gioiHanDangNhapKT   Int? // Giới hạn số khách thuê được bật đăng nhập (null = không giới hạn)
  chuTroBatDangNhapKT Boolean @default(true) // Chủ trọ tắt thêm nếu muốn (mặc định cho phép khi admin bật)

  // ─── Zalo Hotline — 3 công tắc quyền hạn gốc (Giai đoạn 4) ─────────────────
  // Bật Hotline (Đối ngoại): true = khách nhận tin từ Hotline, false = khách nhận từ Zalo cá nhân người xử lý
  batHotline Boolean @default(true)
  // Ủy quyền QL (Thông báo - Đối nội): true = chuyển thông báo cho Quản lý, false = đổ về Chủ trọ
  uyQuyenQL Boolean @default(false)
  // Ủy quyền Hotline (Kỹ thuật): true = Quản lý chịu trách nhiệm bảo trì/quét QR, false = Chủ trọ chịu trách nhiệm
  uyQuyenHotline Boolean @default(false)

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}

// Cài đặt per chủ trọ: thanh toán, cảnh báo, hệ thống, giao diện
model CaiDatChuNha {
  id          String    @id @default(cuid())
  nguoiDungId String    @unique
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)

  // Thanh toán
  nganHangTen         String?
  nganHangSoTaiKhoan  String?
  nganHangChuTaiKhoan String?

  // Cảnh báo & nhắc nhở (số ngày/giờ)
  thongBaoTruocHanHopDong Int @default(30)
  thongBaoQuaHanHoaDon    Int @default(3)
  hoaDonCanhBaoLan1       Int @default(3)
  hoaDonCanhBaoLan2       Int @default(7)
  hoaDonCanhBaoLan3       Int @default(14)
  hopDongCanhBaoLan1      Int @default(30)
  hopDongCanhBaoLan2      Int @default(15)
  hopDongCanhBaoLan3      Int @default(7)
  chotChiSoNgayTrongThang Int @default(1)
  chotChiSoTruocNgay      Int @default(5)
  suCoChuaNhanGio         Int @default(24)
  suCoChuaXuLyGio         Int @default(72)

  // Hệ thống
  tenCongTy    String?
  emailLienHe  String?
  sdtLienHe    String?
  diaChiCongTy String?
  appDomainUrl String? // Domain công khai của chủ trọ

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}

// Danh sách bạn bè Zalo theo từng tài khoản bot
// Được sync khi bot server đăng nhập + khi cần kiểm tra bạn bè real-time
model ZaloBanBe {
  id            String   @id @default(cuid())
  zaloAccountId String // ID tài khoản bot (ownId)
  friendUserId  String // ID bạn bè trên Zalo
  displayName   String? // Tên hiển thị
  zaloName      String? // Tên Zalo
  phone         String? // SĐT (nếu có)
  ngayTao       DateTime @default(now())
  ngayCapNhat   DateTime @updatedAt

  @@unique([zaloAccountId, friendUserId])
  @@index([friendUserId])
  @@index([zaloAccountId])
}

// Danh bạ ngoài — liên hệ thêm thủ công bởi user (không có trong hệ thống)
model DanhBaNgoai {
  id          String    @id @default(cuid())
  ten         String
  soDienThoai String?
  threadId    String?
  nguoiTaoId  String
  nguoiTao    NguoiDung @relation(fields: [nguoiTaoId], references: [id])
  ngayTao     DateTime  @default(now())
  ngayCapNhat DateTime  @updatedAt

  @@index([nguoiTaoId])
}

// ─── Cấu hình Email SMTP (Giai đoạn 4) ───────────────────────────────────────
model CaiDatEmail {
  id          String   @id @default(cuid())
  nguoiDungId String   @unique
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id], onDelete: Cascade)

  email       String   // Email gửi
  appPassword String   // App Password (mã hóa)
  host        String   @default("smtp.gmail.com")
  port        Int      @default(587)
  tenHienThi  String?  // Tên hiển thị khi gửi

  // Bật/tắt tự động gửi theo loại
  tuDongGuiHoaDon  Boolean @default(false)
  tuDongGuiNhacNo  Boolean @default(false)
  tuDongGuiBaoCao  Boolean @default(false)
  tuDongGuiBaoTri  Boolean @default(false)

  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt
}

// Lịch sử gửi Email
model EmailLog {
  id          String   @id @default(cuid())
  nguoiDungId String
  nguoiDung   NguoiDung @relation(fields: [nguoiDungId], references: [id])
  toEmail     String
  tieuDe      String
  noiDung     String?
  loai        String   // hoaDon | nhacNo | baoCao | baoTri | khac
  trangThai   String   @default("thanhCong") // thanhCong | thatBai
  loiNhac     String?  // Thông báo lỗi nếu thất bại
  ngayGui     DateTime @default(now())

  @@index([nguoiDungId, ngayGui])
  @@index([loai, ngayGui])
}

// ─── Công việc / Task — Kanban (Giai đoạn 5) ─────────────────────────────────
model CongViec {
  id            String   @id @default(cuid())
  tieuDe        String
  moTa          String?
  loai          String   // suCo | baoTri | baoDuong | hanhChinh | khac
  trangThai     String   @default("choTiepNhan")
  // choTiepNhan | dangXuLy | tamHoan | choXacNhan | daHoanThanh | daHuy

  mucDoUuTien   String   @default("trungBinh") // thap | trungBinh | cao | khanCap
  deadline      DateTime?

  // Liên kết
  toaNhaId      String?
  toaNha        ToaNha?  @relation(fields: [toaNhaId], references: [id], onDelete: SetNull)
  phongId       String?
  phong         Phong?   @relation(fields: [phongId], references: [id], onDelete: SetNull)
  suCoId        String?  // Liên kết đến sự cố nếu có
  hoaDonId      String?  // Liên kết đến hóa đơn nếu có

  // Người tạo và người xử lý
  nguoiTaoId    String
  nguoiTao      NguoiDung @relation("CongViecNguoiTao", fields: [nguoiTaoId], references: [id])
  nguoiXuLyId   String?
  nguoiXuLy     NguoiDung? @relation("CongViecNguoiXuLy", fields: [nguoiXuLyId], references: [id], onDelete: SetNull)

  // Ghi chú xử lý
  ghiChuXuLy    String?
  ketQua        String?   // Kết quả sau khi hoàn thành

  ngayTao       DateTime  @default(now())
  ngayCapNhat   DateTime  @updatedAt
  ngayHoanThanh DateTime?

  lichSu        CongViecLichSu[]

  @@index([toaNhaId, trangThai])
  @@index([nguoiXuLyId, trangThai])
  @@index([nguoiTaoId])
}

// Lịch sử thay đổi công việc
model CongViecLichSu {
  id              String   @id @default(cuid())
  congViecId      String
  congViec        CongViec @relation(fields: [congViecId], references: [id], onDelete: Cascade)
  nguoiThayDoiId  String
  nguoiThayDoi    NguoiDung @relation(fields: [nguoiThayDoiId], references: [id])
  thayDoi         Json     // { truoc: {...}, sau: {...} }
  ngayTao         DateTime @default(now())

  @@index([congViecId])
}

// ─── Kho bãi (Giai đoạn 6) ───────────────────────────────────────────────────
// Danh mục vật tư
model VatTu {
  id            String   @id @default(cuid())
  maVatTu       String   @unique
  tenVatTu      String
  donViTinh     String   // cai | bo | kg | met | hop | thung
  moTa          String?
  nhomVatTu     String   // dien | nuoc | noiThat | veSinh | anNinh | vanPhong | khac

  // Phân tích ABC
  phanTichABC   String   @default("C") // A | B | C

  // Định mức
  tonKhoToiThieu Int     @default(0)

  // Hình ảnh
  anhVatTu      String[]
  maQR          String?  // Mã QR vật tư (URL hoặc base64)

  // Giá
  giaMua        Float    @default(0)
  giaBan        Float    @default(0)

  ngayTao       DateTime @default(now())
  ngayCapNhat   DateTime @updatedAt

  tonKho        TonKho[]
  nhapKho       PhieuNhapKhoChiTiet[]
  xuatKho       PhieuXuatKhoChiTiet[]
}

// Tồn kho theo tòa nhà/kho
model TonKho {
  id          String   @id @default(cuid())
  vatTuId     String
  vatTu       VatTu    @relation(fields: [vatTuId], references: [id], onDelete: Cascade)
  toaNhaId    String
  toaNha      ToaNha   @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)
  soLuong     Int      @default(0)
  viTri       String?  // Vị trí lưu kho (kệ, phòng...)

  @@unique([vatTuId, toaNhaId])
  @@index([toaNhaId])
}

// Phiếu nhập kho
model PhieuNhapKho {
  id            String   @id @default(cuid())
  maPhieu       String   @unique
  toaNhaId      String
  toaNha        ToaNha   @relation(fields: [toaNhaId], references: [id])
  nguoiNhapId   String
  nguoiNhap     NguoiDung @relation(fields: [nguoiNhapId], references: [id])
  nhaCungCap    String?
  ghiChu        String?
  tongTien      Float    @default(0)
  ngayNhap      DateTime @default(now())
  ngayTao       DateTime @default(now())

  chiTiet       PhieuNhapKhoChiTiet[]

  @@index([toaNhaId, ngayNhap])
}

model PhieuNhapKhoChiTiet {
  id          String         @id @default(cuid())
  phieuNhapId String
  phieuNhap   PhieuNhapKho   @relation(fields: [phieuNhapId], references: [id], onDelete: Cascade)
  vatTuId     String
  vatTu       VatTu          @relation(fields: [vatTuId], references: [id])
  soLuong     Int
  donGia      Float
  thanhTien   Float

  @@index([phieuNhapId])
}

// Phiếu xuất kho
model PhieuXuatKho {
  id            String   @id @default(cuid())
  maPhieu       String   @unique
  toaNhaId      String
  toaNha        ToaNha   @relation(fields: [toaNhaId], references: [id])
  nguoiXuatId   String
  nguoiXuat     NguoiDung @relation(fields: [nguoiXuatId], references: [id])
  lyDo          String   // baoTri | suCo | khac
  phongId       String?  // Phòng sử dụng (nếu có)
  phong         Phong?   @relation(fields: [phongId], references: [id], onDelete: SetNull)
  suCoId        String?  // Liên kết sự cố (nếu có)
  ghiChu        String?
  ngayXuat      DateTime @default(now())
  ngayTao       DateTime @default(now())

  chiTiet       PhieuXuatKhoChiTiet[]

  @@index([toaNhaId, ngayXuat])
}

model PhieuXuatKhoChiTiet {
  id          String          @id @default(cuid())
  phieuXuatId String
  phieuXuat   PhieuXuatKho    @relation(fields: [phieuXuatId], references: [id], onDelete: Cascade)
  vatTuId     String
  vatTu       VatTu           @relation(fields: [vatTuId], references: [id])
  soLuong     Int
  donGia      Float
  thanhTien   Float

  @@index([phieuXuatId])
}

// ─── Bảo dưỡng định kỳ (Giai đoạn 6) ─────────────────────────────────────────
model BaoDuong {
  id            String   @id @default(cuid())
  tieuDe        String
  moTa          String?
  toaNhaId      String
  toaNha        ToaNha   @relation(fields: [toaNhaId], references: [id])
  phongId       String?
  phong         Phong?   @relation(fields: [phongId], references: [id], onDelete: SetNull)

  // Thiết bị
  thietBi       String   // tenThietBi
  loaiBaoDuong  String   // dinhKy | dotXuat

  // Chu kỳ
  chuKyNgay    Int      // Số ngày giữa các lần bảo dưỡng
  ngayBaoDuongTruoc DateTime? // Lần bảo dưỡng trước
  ngayBaoDuongSau   DateTime? // Lần bảo dưỡng tiếp theo (dự kiến)

  // Người phụ trách
  nguoiPhuTrachId String?
  nguoiPhuTrach   NguoiDung? @relation("BaoDuongNguoiPhuTrach", fields: [nguoiPhuTrachId], references: [id], onDelete: SetNull)

  // Trạng thái
  trangThai     String   @default("chuaDenHan") // chuaDenHan | denHan | quaHan | daHoanThanh

  // Kết quả
  ketQua        String?  // Ghi chú kết quả bảo dưỡng
  vatTuDaDung   Json?    // [{ vatTuId, tenVatTu, soLuong }] — vật tư đã dùng

  ngayTao       DateTime @default(now())
  ngayCapNhat   DateTime @updatedAt
  ngayHoanThanh DateTime?

  lichSu        BaoDuongLichSu[]

  @@index([toaNhaId, trangThai])
  @@index([ngayBaoDuongSau])
}

// Lịch sử bảo dưỡng
model BaoDuongLichSu {
  id                String   @id @default(cuid())
  baoDuongId        String
  baoDuong          BaoDuong @relation(fields: [baoDuongId], references: [id], onDelete: Cascade)
  nguoiThucHienId   String
  nguoiThucHien     NguoiDung @relation(fields: [nguoiThucHienId], references: [id])
  noiDung           String
  ketQua            String?
  ngayTao           DateTime @default(now())

  @@index([baoDuongId])
}

// ─── Lịch trực ca (Giai đoạn 3) ──────────────────────────────────────────────
// Mỗi người có một ca trong một ngày tại một tòa nhà
model LichTrucCa {
  id          String   @id @default(cuid())
  nguoiDungId String
  toaNhaId    String
  ngay        DateTime // Ngày trực (chỉ lấy phần ngày, giờ = 00:00:00)
  ca          String   // C1 (Sáng 06-14) | C2 (Chiều 14-22) | C3 (Đêm 22-06) | HC (Hành chính 08-17)
  ghiChu      String?
  nguoiTaoId  String? // Người tạo lịch trực
  ngayTao     DateTime @default(now())
  ngayCapNhat DateTime @updatedAt

  nguoiDung NguoiDung  @relation("NguoiDungLichTruc", fields: [nguoiDungId], references: [id], onDelete: Cascade)
  toaNha    ToaNha     @relation(fields: [toaNhaId], references: [id], onDelete: Cascade)
  nguoiTao  NguoiDung? @relation("NguoiTaoLichTruc", fields: [nguoiTaoId], references: [id], onDelete: SetNull)

  // Một người chỉ có một ca trong một ngày tại một tòa nhà
  @@unique([nguoiDungId, toaNhaId, ngay])
  @@index([toaNhaId, ngay])
  @@index([nguoiDungId])
}

// Danh sách endpoint của Zalo Bot Server — seed từ code, proxy dùng làm whitelist
model ZaloBotApi {
  id             String   @id @default(cuid())
  endpoint       String   @unique // e.g. "/api/sendMessageByAccount"
  method         String   @default("POST")
  nhom           String // auth | zalo_direct | by_account | friend | group | message | board | conversation | account | webhook
  tenNhom        String // tên nhóm hiển thị
  moTa           String?
  defaultPayload String? // JSON template mặc định
  thuTu          Int      @default(0)
  ngayTao        DateTime @default(now())
}
